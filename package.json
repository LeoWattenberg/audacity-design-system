{
  "name": "audacity-design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Audacity Design System - Reusable UI components for audio editing applications",
  "scripts": {
    "dev": "pnpm --parallel --recursive dev",
    "sandbox": "pnpm --filter @audacity-ui/sandbox dev",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "lint": "pnpm --recursive lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "guard:any": "node scripts/check-any.mjs"
  },
  "keywords": [
    "audacity",
    "design-system",
    "audio",
    "components",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DilsonsPickles/audacity-design-system.git"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.12",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "dependencies": {
    "tone": "^15.1.22"
  }
}
